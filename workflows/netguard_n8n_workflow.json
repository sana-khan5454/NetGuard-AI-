              "id": "2978ee95-fd52-4961-8cb1-f6440bcc2029",
              "name": "slack_message",
              "type": "string",
              "value": "=NetGuard AI Alert\nScore: {{ $json.incidents[0].anomaly_score }}\nSource: {{ $json.incidents[0].row_details.src_ip }}\nDestination: {{ $json.incidents[0].row_details.dst_ip }}\nProtocol/Port: {{ $json.incidents[0].row_details.protocol }}/{{ $json.incidents[0].row_details.port }}\nBytes: {{ $json.incidents[0].row_details.bytes_sent }}\nPackets: {{ $json.incidents[0].row_details.packets }}\nMatched Incident: {{ $json.incidents[0].matched_incident.incident_type }}\nRemediation: {{ $json.incidents[0].remediation }}"
