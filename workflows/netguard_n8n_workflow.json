              }
            },
            {
              "id": "efcc3642-c9f7-4be6-b365-fe02f57c05fb",
              "leftValue": "={{ $json.incidents[0]?.anomaly_score || 0 }}",
              "rightValue": 70,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "df73ee7f-b61b-4536-aafb-64c39af75d4e",
